PORT=3000
NODE_ENV=development
JWT_SECRET=local-development-secret-change-before-production
JWT_EXPIRES_IN=15m
JSON_BODY_LIMIT=100kb

# Required in production while demo users are active.
# Use strong values on Railway.
ADMIN_PASSWORD=admin123
TECHNICIAN_PASSWORD=tech123
REPORTER_PASSWORD=reporter123

# Optional. Leave empty for same-origin frontend + backend proxy.
# For split deployments, use a comma-separated list, e.g.
# CORS_ORIGIN=https://your-frontend.up.railway.app
CORS_ORIGIN=

# Optional Brevo/SMTP email notifications
# Use a Brevo SMTP key here, not a Brevo API key.
EMAIL_TRANSPORT=
EMAIL_FROM="IT Ticketer <noreply@example.com>"
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=

# Optional future PostgreSQL settings.
# Railway usually provides DATABASE_URL when you attach PostgreSQL.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=ticketer
PGUSER=postgres
PGPASSWORD=
PGSSL=false

# Optional future Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379

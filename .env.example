PORT=3000
NODE_ENV=development
JWT_SECRET=local-development-secret-change-before-production
JWT_EXPIRES_IN=15m
JSON_BODY_LIMIT=100kb

# Required in production while demo users are active.
# Use strong values on Railway.
ADMIN_PASSWORD=admin123
TECHNICIAN_PASSWORD=tech123
REPORTER_PASSWORD=reporter123

# Optional. Leave empty for same-origin frontend + backend proxy.
# For split deployments, use a comma-separated list, e.g.
# CORS_ORIGIN=https://your-frontend.up.railway.app
CORS_ORIGIN=

# Optional Brevo/SMTP email notifications
# Use a Brevo SMTP key here, not a Brevo API key.
EMAIL_TRANSPORT=
EMAIL_FROM="IT Ticketer <noreply@example.com>"
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=

# === PostgreSQL ===
# Full PostgreSQL connection string; takes precedence over individual PG* vars when set.
DATABASE_URL=postgresql://app_user:CHANGE_ME@localhost:5432/app_db
# PostgreSQL host.
PGHOST=localhost
# PostgreSQL port.
PGPORT=5432
# Database name.
PGDATABASE=app_db
# PostgreSQL user.
PGUSER=app_user
# PostgreSQL password.
PGPASSWORD=CHANGE_ME
# Set to `true` to enable SSL for PostgreSQL connections.
PGSSL=false
# Alternative SSL flag (same effect as PGSSL).
DATABASE_SSL=false
# Maximum pool connections (1-100).
PG_POOL_MAX=10

# === Redis ===
# Full Redis connection string; takes precedence over REDIS_HOST/PORT.
REDIS_URL=redis://localhost:6379
# Redis host.
REDIS_HOST=localhost
# Redis port.
REDIS_PORT=6379

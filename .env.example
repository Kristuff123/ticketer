PORT=3000
JWT_SECRET=change-me-in-production

# Optional Brevo/SMTP email notifications
# Use a Brevo SMTP key here, not a Brevo API key.
EMAIL_TRANSPORT=
EMAIL_FROM="IT Ticketer <noreply@example.com>"
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=

# Optional future PostgreSQL settings
PGHOST=localhost
PGPORT=5432
PGDATABASE=ticketer
PGUSER=postgres
PGPASSWORD=

# Optional future Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
